---
import Layout from '../layouts/Layout.astro';

const links = [
  { href: 'https://www.farming-simulator.com/mod.php?mod_id=337612&title=fs2025', label: 'FS25_Animalic (custom animal food mod)' },
  { href: 'https://sashaman.github.io/links/fs25_animalic_food.html', label: 'Futter-Übersicht für FS25_Animalic' },
  { href: 'https://www.farming-simulator.com/mod.php?mod_id=337619&title=fs2025', label: 'FS25 Baumenü Zoom' },
];

const categories = [
  {
    id: 'community',
    label: 'Discord & community',
    header: '// discord & community',
    behavior: 'both',
    timing: 'snappy',
    links: [
      { href: 'https://discord.gg/FarmingDuds', label: '🚜🌽 Farming Duds Discord 🛻🧑🌾' },
      { href: 'https://discord.gg/Qya9GTTzTw', label: '🌽 Maize+ Discord' },
      { href: 'https://discord.gg/2y3MG7m7eG', label: '🌽 Alte Gefilde Discord - FS19 Odenwälderlande' },
    ],
  },
  {
    id: 'mods',
    label: 'Mods & uploads',
    header: '// mods & uploads',
    behavior: 'swap',
    timing: 'dramatic',
    links: [
      { href: 'https://github.com/sashaman/FS22_stoppelfahrspur', label: 'FS22 Stoppelfahrspur / Stubble Lane - for all crops + special 🌽 Maize' },
      { href: 'https://github.com/sashaman/HorseExtension', label: '🌽 Maize+ 🐴 Horse Extension 🤓 DIY guide' },
      { href: 'https://workupload.com/file/vBxCMjJursV', label: '💧🗜️🩸 FS19_compostteaProdi' },
      { href: 'https://workupload.com/file/Q7hJcZsCtKX', label: '🛢️ FS19_PlaceableTriggerFuelTank' },
      { href: 'https://workupload.com/file/baWdALDUQRJ', label: '⛽ FS19_PlaceableTriggerFuelBuyingStation' },
      { href: 'https://workupload.com/file/zMyNAUzkpRS', label: '💧 FS19_PlaceableTriggerWaterBuyingStation' },
      { href: 'https://www.farming-simulator.com/mods.php?title=fs2025&filter=org&org_id=194125', label: '🍿 my FS25 Modhub Mods' },
    ],
  },
  {
    id: 'resources',
    label: 'Lists & tools',
    header: '// lists & tools',
    behavior: 'accordion',
    timing: 'calm',
    links: [
      { href: 'https://docs.google.com/spreadsheets/d/18kgYaqGbwny9IDG6Mh1ECIfQuomc9QRRE-foNfD1WGw/', label: '🚜🌻 FarmingDud\'s ✔️ FS22 mod list' },
      { href: 'https://docs.google.com/spreadsheets/d/1DMjn6HHMz7rVnhJiDhI940AfTOrmi4Yy4Kv2WJzmchk/', label: '🌻 FarmingDud\'s ✔️ FS19 mod list' },
      { href: 'https://www.farming-simulator.com/mods.php?title=fs2025&filter=org&org_id=194125', label: '🍿 Farming Simulator 25 Mods' },
      { href: 'https://gdn.giants-software.com/', label: '📚 GIANTS Developer Network' },
      { href: 'https://emojipedia.org/', label: 'Emojipedia ✂️ Copy and 📋 Paste Emoji 👍' },
      { href: 'https://astro.build/', label: '💫 Astro 🌌 The web framework for content-driven websites 🛠️' },
    ],
  },
];

function behaviorFlags(behavior) {
  return {
    swap: behavior === 'swap' || behavior === 'both',
    accordion: behavior === 'accordion' || behavior === 'both',
    label:
      behavior === 'both'
        ? '1+2'
        : behavior === 'swap'
          ? '1'
          : behavior === 'accordion'
            ? '2'
            : '0',
  };
}

const username = '@sashaman';
const userPhoto = `${import.meta.env.BASE_URL}/img/aoum.png`;
---

<Layout
  title="Sash's Termlink"
  description="Terminal-style links for @sashaman — Discord communities, GitHub repos, Farming Simulator mods, and tools."
  ogTitle="Sash's Termlink — @sashaman"
  ogSiteName="sashaman"
  ogImage="img/termlink-og.png"
  ogImageAlt="Sash's Termlink — terminal link hub (Farming Simulator & community links)"
  themeColor="#0a0a0a"
>
  <div class="min-h-screen bg-black p-6 font-mono">
    <div class="fixed inset-0 pointer-events-none opacity-[0.03] z-50" style="background: repeating-linear-gradient(0deg, transparent, transparent 2px, #00ff00 2px, #00ff00 4px);"></div>

    <div class="max-w-2xl mx-auto pt-12">
      <div class="mb-8 text-xs text-green-500/60">
        <span class="text-green-400">sash</span>@<span class="text-blue-400">links</span>:~$ <span class="text-yellow-400">./init.sh</span>
      </div>

      <div class="mb-6 flex items-center gap-4">
        <img
          src={userPhoto}
          alt="avatar"
          class="w-16 h-16 rounded-lg border border-green-500/40 shadow-[0_0_15px_rgba(0,255,0,0.2)]"
        />
        <div>
          <div class="text-green-400 text-sm">root@sashaman</div>
          <div class="flex items-center gap-2 text-gray-500 text-xs">
            <span class="h-2 w-2 rounded-full bg-green-400 animate-pulse"></span>
            <span>status: online</span>
          </div>
        </div>
      </div>

      <div id="nav-shell" class="relative rounded-lg">
        <div
          id="category-view"
          class="nav-panel flex flex-col transition-all duration-[610ms] ease-out motion-reduce:duration-150"
        >
          {links.length > 0 && (
            <>
              <div class="mb-2 text-xs text-gray-500">// direct modules</div>
              <div class="space-y-2 mb-5">
                {links.map((link, i) => (
                  <a
                    href={link.href}
                    target="_blank"
                    rel="noopener"
                    title={link.href}
                    class="terminal-link w-full text-left flex items-center gap-3 py-3 px-4 bg-gray-900/50 border border-gray-800 rounded hover:border-green-500/50 hover:bg-green-500/5 hover:scale-[1.02] transition-all duration-300 transform-gpu group"
                    style={`animation-delay: ${i * 60}ms`}
                  >
                    <span class="text-green-500/40 text-xs font-mono w-6">[{i.toString().padStart(2, '0')}]</span>
                    <span class="inline-flex items-center px-2 py-[2px] rounded border border-cyan-500/40 text-[10px] tracking-wider text-cyan-300/90">
                      FILE
                    </span>
                    <span class="text-gray-300 group-hover:text-green-400 text-sm font-mono flex-1 min-w-0 truncate">
                      {link.label}
                    </span>
                    <span class="text-green-500/30 text-xs opacity-0 group-hover:opacity-100 transition-opacity shrink-0">►</span>
                  </a>
                ))}
              </div>
            </>
          )}

          <div class="mb-2 text-xs text-gray-500">// module categories — select to expand</div>
          <div class="space-y-2" id="category-list">
            {categories.map((cat, i) => {
              const flags = behaviorFlags(cat.behavior ?? 'both');
              const rowClass = flags.swap
                ? 'category-tile w-full text-left flex items-center gap-3 py-3 px-4 bg-gray-900/50 border border-gray-800 rounded hover:border-green-500/50 hover:bg-green-500/5 hover:scale-[1.02] transition-all duration-300 transform-gpu group cursor-pointer'
                : 'category-tile w-full text-left flex items-center gap-3 py-3 px-4 bg-gray-900/30 border border-gray-800/70 rounded transition-all duration-300 transform-gpu opacity-85';

              return (
                <div class="category-group">
                  <div class="terminal-link flex items-center gap-2" style={`animation-delay: ${i * 60}ms`}>
                    {flags.swap ? (
                      <button
                        type="button"
                        data-category-open={cat.id}
                        class={rowClass}
                      >
                        <span class="text-green-500/40 text-xs font-mono w-6">[{i.toString().padStart(2, '0')}]</span>
                        <span class="inline-flex items-center px-2 py-[2px] rounded border border-purple-500/40 text-[10px] tracking-wider text-purple-300/90">
                          DIR
                        </span>
                        <span class="text-gray-300 group-hover:text-green-400 text-sm font-mono flex-1 min-w-0">
                          {cat.header}
                        </span>
                        <span class="text-gray-600 text-xs tabular-nums shrink-0">{cat.links.length} modules</span>
                        <span class="inline-flex items-center px-2 py-[2px] rounded border border-gray-700 text-[10px] text-gray-500">
                          {flags.label}
                        </span>
                      </button>
                    ) : (
                      <div class={rowClass}>
                        <span class="text-green-500/40 text-xs font-mono w-6">[{i.toString().padStart(2, '0')}]</span>
                        <span class="inline-flex items-center px-2 py-[2px] rounded border border-purple-500/40 text-[10px] tracking-wider text-purple-300/90">
                          DIR
                        </span>
                        <span class="text-gray-400 text-sm font-mono flex-1 min-w-0">
                          {cat.header}
                        </span>
                        <span class="text-gray-600 text-xs tabular-nums shrink-0">{cat.links.length} modules</span>
                        <span class="inline-flex items-center px-2 py-[2px] rounded border border-gray-700 text-[10px] text-gray-500">
                          {flags.label}
                        </span>
                      </div>
                    )}
                    {flags.accordion && (
                      <button
                        type="button"
                        data-category-accordion={cat.id}
                        aria-expanded="false"
                        aria-label={`Toggle ${cat.label}`}
                        class="category-accordion-toggle shrink-0 h-[44px] px-3 bg-gray-900/50 border border-gray-800 rounded hover:border-green-500/50 hover:bg-green-500/5 transition-all"
                      >
                        <span class="category-chevron text-green-500/40 text-xs opacity-90 transition-all">▼</span>
                      </button>
                    )}
                  </div>
                <div
                  data-cat-slot={cat.id}
                  class="cat-inline-slot hidden space-y-2 mt-2 ml-4 pl-3 border-l border-gray-800/80"
                  aria-hidden="true"
                ></div>
              </div>
              );
            })}
          </div>
        </div>

        <div
          id="links-view"
          class="nav-panel hidden flex flex-col opacity-0 scale-[0.98] transition-all duration-[610ms] ease-out motion-reduce:duration-150 motion-reduce:transition-opacity"
          aria-hidden="true"
        >
          <button
            type="button"
            id="back-categories"
            class="mb-4 self-start flex items-center gap-2 py-2 px-3 text-xs text-yellow-400/90 border border-yellow-500/30 rounded hover:bg-yellow-500/10 hover:border-yellow-500/50 transition-colors"
          >
            <span aria-hidden="true">←</span>
            <span class="font-mono">cd ..</span>
            <span class="text-gray-600">// back to categories</span>
          </button>
          <div id="links-context" class="mb-2 text-xs text-gray-500 font-mono"></div>
          <div id="links-active-slot" class="space-y-2"></div>
        </div>
      </div>

      <div id="links-source" class="hidden" aria-hidden="true">
        {categories.map((cat) => (
          <div data-cat-source={cat.id}>
            {cat.links.map((link, i) => (
              <a
                href={link.href}
                target="_blank"
                rel="noopener"
                title={link.href}
                class="sub-link flex items-center gap-3 py-3 px-4 bg-gray-900/50 border border-gray-800 rounded hover:border-green-500/50 hover:bg-green-500/5 hover:scale-[1.02] transition-all duration-300 transform-gpu group"
                style={`--stagger: ${i * 50}ms`}
              >
                <span class="text-green-500/40 text-xs font-mono w-6">
                  [{i.toString().padStart(2, '0')}]
                </span>
                <span class="inline-flex items-center px-2 py-[2px] rounded border border-cyan-500/40 text-[10px] tracking-wider text-cyan-300/90">
                  FILE
                </span>
                <span class="text-gray-300 group-hover:text-green-400 text-sm font-mono truncate">
                  {link.label}
                </span>
                <span class="ml-auto text-green-500/30 text-xs opacity-0 group-hover:opacity-100 transition-opacity">►</span>
              </a>
            ))}
          </div>
        ))}
      </div>

      <noscript>
        <div class="mt-6 space-y-2">
          <p class="text-gray-500 text-xs mb-2">// all modules (JS disabled)</p>
          {links.map((link) => (
            <a
              href={link.href}
              target="_blank"
              rel="noopener"
              class="flex items-center gap-3 py-3 px-4 bg-gray-900/50 border border-gray-800 rounded text-gray-300 text-sm no-underline hover:border-green-500/50"
            >
              {link.label}
            </a>
          ))}
          {categories.flatMap((cat) =>
            cat.links.map((link) => (
              <a
                href={link.href}
                target="_blank"
                rel="noopener"
                class="flex items-center gap-3 py-3 px-4 bg-gray-900/50 border border-gray-800 rounded text-gray-300 text-sm no-underline hover:border-green-500/50"
              >
                {link.label}
              </a>
            ))
          )}
        </div>
      </noscript>

      <div class="mt-8 pt-4 border-t border-gray-800 text-xs text-gray-600 font-mono">
        <span class="inline-flex items-center gap-2">
          <span class="h-2 w-2 rounded-full bg-green-500 animate-pulse"></span>
          <span>session active // {new Date().getFullYear()}</span>
        </span>
      </div>
    </div>
  </div>
</Layout>

<script
  define:vars={{
    categoryMeta: categories.map((c) => ({
      id: c.id,
      header: c.header,
      timing: c.timing ?? 'balanced',
    })),
  }}
>
  const categoryView = document.getElementById('category-view');
  const linksView = document.getElementById('links-view');
  const slot = document.getElementById('links-active-slot');
  const context = document.getElementById('links-context');
  const sourceRoot = document.getElementById('links-source');
  const backBtn = document.getElementById('back-categories');
  const categoryOpenButtons = document.querySelectorAll('[data-category-open]');
  const categoryAccordionButtons = document.querySelectorAll('[data-category-accordion]');
  const inlineSlots = document.querySelectorAll('[data-cat-slot]');
  let activeAccordionCategory = null;
  let activeSwapCategory = null;

  const PHI = 1.618;
  const TIMING_PROFILES = {
    snappy: {
      swapPanelMs: 377,
      swapStagingMs: 89,
      accordionStagingMs: 144,
      firstGapMs: 55,
      rowDurationMs: 377,
      collapseMs: 233,
    },
    balanced: {
      swapPanelMs: 610,
      swapStagingMs: 144,
      accordionStagingMs: 233,
      firstGapMs: 89,
      rowDurationMs: 610,
      collapseMs: 377,
    },
    dramatic: {
      swapPanelMs: 987,
      swapStagingMs: 233,
      accordionStagingMs: 377,
      firstGapMs: 144,
      rowDurationMs: 987,
      collapseMs: 610,
    },
    calm: {
      swapPanelMs: 754,
      swapStagingMs: 233,
      accordionStagingMs: 377,
      firstGapMs: 89,
      rowDurationMs: 754,
      collapseMs: 610,
    },
  };

  function prefersReducedMotion() {
    return window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  }

  function getSourceRows(id) {
    const src = sourceRoot?.querySelector(`[data-cat-source="${id}"]`);
    if (!src) return [];
    return Array.from(src.children).map((child) => child.cloneNode(true));
  }

  function getCategoryMeta(id) {
    return categoryMeta.find((c) => c.id === id) ?? null;
  }

  function getTimingProfile(id) {
    const profileKey = getCategoryMeta(id)?.timing ?? 'balanced';
    return TIMING_PROFILES[profileKey] ?? TIMING_PROFILES.balanced;
  }

  function setPanelDurations(ms) {
    const value = `${ms}ms`;
    if (categoryView) categoryView.style.transitionDuration = value;
    if (linksView) linksView.style.transitionDuration = value;
  }

  function runRowStagger(container, opts = {}) {
    const rows = container.querySelectorAll('.sub-link');
    const mode = opts.mode ?? 'linear'; // linear | accelerate
    const linearStep = opts.stepMs ?? 55;
    const firstGap = opts.firstGapMs ?? 89; // Fibonacci
    const rowDuration = opts.durationMs ?? 610; // Fibonacci-adjacent

    let accumulated = 0;
    rows.forEach((el, i) => {
      el.classList.remove('sub-link-enter');
      void el.offsetWidth;
      if (mode === 'accelerate') {
        if (i === 0) {
          accumulated = 0;
        } else {
          const interval = Math.max(13, Math.round(firstGap / Math.pow(PHI, i - 1)));
          accumulated += interval;
        }
        el.style.setProperty('--stagger', `${accumulated}ms`);
      } else {
        el.style.setProperty('--stagger', `${i * linearStep}ms`);
      }
      el.style.setProperty('--row-duration', `${rowDuration}ms`);
      el.classList.add('sub-link-enter');
    });
  }

  function closeAccordionCategory(id) {
    if (!id) return;
    const slotEl = document.querySelector(`[data-cat-slot="${id}"]`);
    const btnEl = document.querySelector(`[data-category-accordion="${id}"]`);
    if (!slotEl || !btnEl) return;

    const timing = getTimingProfile(id);
    btnEl.setAttribute('aria-expanded', 'false');
    btnEl.classList.remove('ring-1', 'ring-green-500/20');
    slotEl.classList.remove('accordion-expand', 'accordion-prep');
    slotEl.classList.add('accordion-collapse');

    window.setTimeout(() => {
      slotEl.classList.add('hidden');
      slotEl.classList.remove('accordion-collapse');
      slotEl.setAttribute('aria-hidden', 'true');
      slotEl.replaceChildren();
    }, prefersReducedMotion() ? 0 : timing.collapseMs);
  }

  function toggleAccordionCategory(id) {
    const timing = getTimingProfile(id);
    const slotEl = document.querySelector(`[data-cat-slot="${id}"]`);
    const btnEl = document.querySelector(`[data-category-accordion="${id}"]`);
    if (!slotEl || !btnEl) return;

    if (activeAccordionCategory === id) {
      closeAccordionCategory(id);
      activeAccordionCategory = null;
      return;
    }

    if (activeAccordionCategory && activeAccordionCategory !== id) {
      closeAccordionCategory(activeAccordionCategory);
    }

    slotEl.classList.remove('accordion-collapse', 'accordion-expand');
    slotEl.classList.add('rows-pending', 'accordion-prep');
    slotEl.replaceChildren(...getSourceRows(id));
    slotEl.classList.remove('hidden');
    slotEl.setAttribute('aria-hidden', 'false');
    btnEl.setAttribute('aria-expanded', 'true');
    btnEl.classList.add('ring-1', 'ring-green-500/20');
    void slotEl.offsetWidth;
    slotEl.classList.remove('accordion-prep');
    slotEl.classList.add('accordion-expand');
    window.setTimeout(() => {
      slotEl.classList.remove('rows-pending');
      runRowStagger(slotEl, {
        mode: 'accelerate',
        firstGapMs: timing.firstGapMs,
        durationMs: timing.rowDurationMs,
      });
    }, prefersReducedMotion() ? 0 : timing.accordionStagingMs);
    activeAccordionCategory = id;
  }

  function openCategory(id) {
    if (!slot || !context) return;
    if (activeAccordionCategory) {
      closeAccordionCategory(activeAccordionCategory);
      activeAccordionCategory = null;
    }

    const timing = getTimingProfile(id);
    const meta = getCategoryMeta(id);
    context.textContent = meta?.header ?? '';

    slot.classList.add('rows-pending', 'swap-prep');
    slot.replaceChildren(...getSourceRows(id));

    if (prefersReducedMotion()) {
      categoryView?.classList.add('hidden');
      linksView?.classList.remove('hidden');
      linksView?.classList.remove('opacity-0', 'scale-[0.98]');
      linksView?.classList.add('opacity-100', 'scale-100');
      linksView?.setAttribute('aria-hidden', 'false');

      runRowStagger(slot, {
        mode: 'accelerate',
        firstGapMs: timing.firstGapMs,
        durationMs: timing.rowDurationMs,
      });

      activeSwapCategory = id;
      backBtn?.focus();
      return;
    }

    setPanelDurations(timing.swapPanelMs);
    categoryView?.classList.add('opacity-0', 'scale-95', 'pointer-events-none');

    window.setTimeout(() => {
      categoryView?.classList.add('hidden');
      categoryView?.classList.remove('opacity-0', 'scale-95', 'pointer-events-none');

      linksView?.classList.remove('hidden');
      linksView?.classList.add('opacity-0', 'scale-[0.98]', 'pointer-events-none');
      void linksView?.offsetWidth;
      linksView?.classList.remove('pointer-events-none');
      linksView?.classList.add('opacity-100', 'scale-100');
      linksView?.setAttribute('aria-hidden', 'false');
      void slot?.offsetWidth;
      window.setTimeout(() => {
        slot?.classList.remove('swap-prep', 'rows-pending');
        runRowStagger(slot, {
          mode: 'accelerate',
          firstGapMs: timing.firstGapMs,
          durationMs: timing.rowDurationMs,
        });
      }, timing.swapStagingMs);

      activeSwapCategory = id;
      backBtn?.focus();
    }, timing.swapPanelMs);
  }

  function closeCategory() {
    const timing = getTimingProfile(activeSwapCategory ?? 'resources');
    setPanelDurations(timing.swapPanelMs);
    if (prefersReducedMotion()) {
      linksView?.classList.add('hidden', 'opacity-0', 'scale-[0.98]');
      linksView?.classList.remove('opacity-100', 'scale-100');
      linksView?.setAttribute('aria-hidden', 'true');
      categoryView?.classList.remove('hidden');
      slot?.replaceChildren();
      context.textContent = '';
      activeSwapCategory = null;
      return;
    }

    linksView?.classList.add('pointer-events-none');
    linksView?.classList.remove('opacity-100', 'scale-100');
    linksView?.classList.add('opacity-0', 'scale-[0.98]');

    window.setTimeout(() => {
      linksView?.classList.add('hidden');
      linksView?.classList.remove(
        'opacity-0',
        'scale-[0.98]',
        'opacity-100',
        'scale-100',
        'pointer-events-none'
      );
      linksView?.setAttribute('aria-hidden', 'true');

      categoryView?.classList.remove('hidden');
      categoryView?.classList.add('opacity-0', 'scale-[0.98]');
      void categoryView?.offsetWidth;
      categoryView?.classList.remove('opacity-0', 'scale-[0.98]');

      slot?.classList.remove('swap-prep', 'rows-pending');
      slot?.replaceChildren();
      context.textContent = '';
      activeSwapCategory = null;
    }, timing.collapseMs);
  }

  categoryOpenButtons.forEach((btn) => {
    btn.addEventListener('click', () => {
      const id = btn.getAttribute('data-category-open');
      if (id) openCategory(id);
    });
  });

  categoryAccordionButtons.forEach((btn) => {
    btn.addEventListener('click', (e) => {
      e.preventDefault();
      e.stopPropagation();
      const id = btn.getAttribute('data-category-accordion');
      if (id) toggleAccordionCategory(id);
    });
  });

  linksView?.classList.add('hidden');
  linksView?.setAttribute('aria-hidden', 'true');
  inlineSlots.forEach((el) => el.classList.add('hidden'));

  backBtn?.addEventListener('click', () => closeCategory());

  document.addEventListener('keydown', (e) => {
    if (
      e.key === 'Escape' &&
      linksView &&
      !linksView.classList.contains('hidden') &&
      linksView.getAttribute('aria-hidden') === 'false'
    ) {
      closeCategory();
      return;
    }
    if (e.key === 'Escape' && activeAccordionCategory) {
      closeAccordionCategory(activeAccordionCategory);
      activeAccordionCategory = null;
    }
  });
</script>

<style>
  body {
    background: #0a0a0a;
  }

  @keyframes expandIn {
    from {
      opacity: 0;
      transform: translateY(20px) scaleX(0.4);
      transform-origin: bottom left;
    }
    to {
      opacity: 1;
      transform: translateY(0) scaleX(1);
      transform-origin: bottom left;
    }
  }

  .terminal-link {
    opacity: 0;
    animation: expandIn 0.6s cubic-bezier(0.22, 1, 0.36, 1) forwards;
  }

  @keyframes subLinkIn {
    from {
      opacity: 0;
      transform: translateY(14px) scale(0.98);
    }
